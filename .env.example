# LLM defaults. LLM_API_KEY is optional for local/OpenAI-compatible endpoints that do not require auth.
LLM_BASE_URL=https://ollama.com/v1
LLM_API_KEY=your-key-here
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=60

# Optional multimodal vision overrides. Defaults fall back to LLM_* when unset.
VISION_BASE_URL=https://api.openai.com/v1
VISION_API_KEY=your-key-here
VISION_MODEL=gpt-4o-mini
VISION_TEMPERATURE=0
VISION_TIMEOUT_SECONDS=60

# Whisper defaults for local CPU transcription.
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Artifact and output defaults.
CLIPPER_STORE_PATH=.clipper
DEFAULT_WIDTH=1920
DEFAULT_HEIGHT=1080
DEFAULT_MIN_SCORE=6
